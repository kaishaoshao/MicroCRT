<!DOCTYPE CrossStudio_Project_File>
<solution Name="SEGGER-RTL" version="2">
  <configuration Name="Common" arm_compiler_variant="gcc" build_intermediate_directory="../../lib/Output/$(ConfigurationHash)/$(ProjectName)" build_output_directory="../../lib" build_output_file_name="$(OutDir)/$(ProjectName)$(LibExt)$(LIB)" default_code_section=".text.libc" default_const_section=".rodata.libc" default_data_section=".data.libc" default_zeroed_section=".bss.libc" generate_stack_sizes="No" />
  <configuration Name="Andes" generate_stack_sizes="No" />
  <configuration Name="Small" c_preprocessor_definitions="__SEGGER_RTL_OPTIMIZE=-2" />
  <configuration Name="Balanced" c_preprocessor_definitions="__SEGGER_RTL_OPTIMIZE=0" />
  <configuration Name="Fast" c_preprocessor_definitions="__SEGGER_RTL_OPTIMIZE=2" />
  <project Name="all">
    <configuration Name="Common" batch_build_configurations="Common" project_dependencies="libc;heapops_basic;heapops_minimal;heapops_realtime;heapops_disable_interrupts_locking;heapops_user_locking;prinops_rtt;prinops_semihost;prinops_semihostformatted;mbops_timeops;mbops_timeops_minimal_locale" project_type="Staging" />
  </project>
  <project Name="libc" template_name="MULTILIB_SEGGER">
    <configuration Name="Common" gcc_unused_variable_warning="No" />
    <folder Name="Source Files">
      <file file_name="atomicops.c">
