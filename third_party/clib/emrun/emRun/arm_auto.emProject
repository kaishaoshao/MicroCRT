<!DOCTYPE CrossStudio_Project_File>
<solution Name="SEGGER-RTL" version="2">
  <configuration Name="Common" arm_compiler_variant="gcc" arm_unaligned_access="No" build_intermediate_directory="../../lib/Output/$(ConfigurationHash)/$(ProjectName)" build_output_directory="../../lib" build_output_file_name="$(OutDir)/$(ProjectName)$(LibExt)$(LIB)" default_code_section=".text.libc" default_const_section=".rodata.libc" default_data_section=".data.libc" default_zeroed_section=".bss.libc" generate_stack_sizes="No" />
  <configuration Name="Small" c_preprocessor_definitions="__SEGGER_RTL_OPTIMIZE=-2" />
  <configuration Name="Balanced" c_preprocessor_definitions="__SEGGER_RTL_OPTIMIZE=0" />
  <configuration Name="Fast" c_preprocessor_definitions="__SEGGER_RTL_OPTIMIZE=2" />
  <configuration Name="THUMB" arm_compiler_variant="SEGGER" />
  <configuration Name="V4" arm_compiler_variant="gcc" />
